{
  "name": "agent-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for agent architecture demos and deployable sub-apps.",
  "type": "commonjs",
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "apps:list": "node scripts/list-apps.mjs",
    "demo:spiffe": "pnpm --filter @agent-demo/spiffe-mtls-agent demo:web",
    "start:spiffe": "pnpm --filter @agent-demo/spiffe-mtls-agent start:web"
  }
}